  "keyFeatures": [
    "CPU instruction execution with fetch-decode-execute cycle",
    "Memory management with paging and page replacement algorithms (FIFO, LRU)",
    "Process scheduling with multiple algorithms (FIFO, Round Robin, Priorities)",
    "Filesystem with FAT implementation and swap space management",
    "Inter-process communication using sockets and custom protocol",
    "Resource management with deadlock detection",
    "Configurable system parameters for each component"
  ],
  "publicApiSurface": [
    "CPU: SET, SUM, SUB, MOV_IN, MOV_OUT, SLEEP, WAIT, SIGNAL, EXIT, JNZ instructions",
    "CPU: F_OPEN, F_CLOSE, F_SEEK, F_READ, F_WRITE, F_TRUNCATE file operations",
    "Memory: Page table management, TLB, page fault handling",
    "Memory: FIFO and LRU page replacement algorithms",
    "Kernel: INICIAR_PROCESO, FINALIZAR_PROCESO, DETENER_PLANIFICACION, INICIAR_PLANIFICACION",
    "Kernel: MULTIPROGRAMACION, PROCESO_ESTADO console commands",
    "Kernel: FIFO, Round Robin, and Priority scheduling algorithms",
    "Filesystem: FAT operations, block allocation/deallocation",
    "Filesystem: Swap space reservation and liberation",
    "Utils: Socket-based communication protocol"
  ]
}
